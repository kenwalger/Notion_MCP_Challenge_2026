# Notion Integration Token (create at https://www.notion.so/my-integrations)
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# General books catalog – used by search_books
NOTION_BOOKS_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Master Bibliography – Ground Truth for audit_artifact_consistency (forensic audit)
NOTION_MASTER_BIBLIOGRAPHY_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Market Results – hammer prices for get_market_signals (Title, Author, Hammer Price, Sale Date)
NOTION_MARKET_RESULTS_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Audit Logs – permanent audit records for create_audit_log (Title, Book Title, Result, Summary, Full Report)
NOTION_AUDIT_LOG_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
